APP_IMAGE=your-dockerhub-id/spring-cgv-23rd:latest
APP_PORT=8080
DB_URL=jdbc:mysql://localhost:3306/cgv_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
JWT_SECRET=your_base64_encoded_jwt_secret
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JWT_ACCESS_TOKEN_VALIDITY_IN_SECONDS=3600
JWT_REFRESH_TOKEN_VALIDITY_IN_SECONDS=1209600
