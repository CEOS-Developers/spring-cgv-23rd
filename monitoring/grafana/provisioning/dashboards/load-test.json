{
  "title": "Load Test Dashboard",
  "uid": "load-test",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["k6", "loadtest", "hikari"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Total RPS",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": ""},
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Failure Rate",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{outcome=~\"SERVER_ERROR|CLIENT_ERROR\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m]))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 15}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": ""}
      }
    },
    {
      "id": 3,
      "title": "p95 Latency",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": ""}
      }
    },
    {
      "id": 4,
      "title": "p99 Latency",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 4}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": ""}
      }
    },
    {
      "id": 5,
      "title": "RPS by Endpoint",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {"mode": "none"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 6,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 7,
      "title": "LockHikariPool (★ 핵심)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "hikaricp_connections_active{pool=\"LockHikariPool\"}",
          "legendFormat": "active",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "hikaricp_connections_pending{pool=\"LockHikariPool\"}",
          "legendFormat": "pending",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "hikaricp_connections{pool=\"LockHikariPool\"}",
          "legendFormat": "max",
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "pending"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "active"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
          },
          {
            "matcher": {"id": "byName", "options": "max"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}, {"id": "custom.lineStyle", "value": {"fill": "dash"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 8,
      "title": "MainHikariPool",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "hikaricp_connections_active{pool=\"MainHikariPool\"}",
          "legendFormat": "active",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "hikaricp_connections_pending{pool=\"MainHikariPool\"}",
          "legendFormat": "pending",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "hikaricp_connections{pool=\"MainHikariPool\"}",
          "legendFormat": "max",
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 9,
      "title": "Connection Acquire Time (avg / max per pool)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum[1m]) / rate(hikaricp_connections_acquire_seconds_count[1m])",
          "legendFormat": "{{pool}} avg",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "hikaricp_connections_acquire_seconds_max",
          "legendFormat": "{{pool}} max",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 10,
      "title": "EC2 CPU %",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 28, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "cpu",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list"},
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 11,
      "title": "EC2 Memory %",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 28, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "memory",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list"},
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 12,
      "title": "EC2 Network I/O",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 28, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[1m])",
          "legendFormat": "{{device}} in",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m])",
          "legendFormat": "{{device}} out",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      }
    }
  ]
}
